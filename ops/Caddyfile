{
  auto_https off
  admin off
}

:8080 {
  root * /srv
  encode zstd gzip
  respond /healthz 200
  file_server

  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(), geolocation=(), microphone=()"
    X-Frame-Options "SAMEORIGIN"
  }
}
