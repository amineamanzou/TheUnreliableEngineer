---
import PersonaPlaceholder from "../components/PersonaPlaceholder.astro";
import { homepageFr } from "../data/homepage.fr";
import BaseLayout from "../layouts/BaseLayout.astro";

const page = homepageFr;
const assetPath = (path: string) =>
  path.startsWith("/") ? `${import.meta.env.BASE_URL}${path.slice(1)}` : path;
---

<BaseLayout title={page.meta.title} description={page.meta.description}>
  <header class="topbar">
    <div class="shell shell-wide topbar-inner">
      <a class="brand" href="#top" aria-label={`Accueil ${page.topbar.brand}`}>
        <span class="brand-mark" aria-hidden="true"></span>
        <span class="brand-copy">
          <span class="brand-title">{page.topbar.brand}</span>
        </span>
      </a>
    </div>
  </header>

  <main class="page">
    <section class="hero-band" id="top">
      <div class="shell shell-wide hero">
        <article class="panel hero-copy">
          <div class="stack hero-copy-stack">
            <div class="eyebrow" data-review="credibility">{page.hero.eyebrow}</div>
            <h1>{page.hero.title}</h1>
            <p class="hero-text hero-audience" data-review="audience">{page.hero.audience}</p>
            <p class="hero-offer-line" data-review="offer">{page.hero.offerLine}</p>
            <p class="hero-text">{page.hero.body}</p>
            <div class="hero-actions">
              <a class="button button-primary" href={page.hero.primaryCta.href}>
                {page.hero.primaryCta.label}
              </a>
              <a class="button button-secondary" href={page.hero.secondaryCta.href}>
                {page.hero.secondaryCta.label}
              </a>
            </div>
          </div>
        </article>

        <div class="hero-stage">
          <article class="panel hero-stage-board hero-clarifier-card">
            <div class="slot-label slot-label-ink">{page.hero.consultation.label}</div>
            <div class="hero-clarifier-layout">
              <PersonaPlaceholder
                src="/brand/web/characters/camera.png"
                alt="The Unreliable Engineer présente son point de vue éditorial"
                class="hero-character"
                loading="eager"
              />
              <div class="case-caption">
                <strong>{page.hero.consultation.caption}</strong>
                <p>{page.hero.consultation.body}</p>
              </div>
            </div>
            <ul class="spec-list">
              {page.hero.consultation.points.map((spec) => (
                <li>
                  <span class="spec-label">{spec.label}</span>
                  <span class="spec-value">{spec.value}</span>
                </li>
              ))}
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section class="proof-band" id="proof">
      <div class="shell shell-wide">
        <div class="panel proof-wrap">
          <div class="proof-head">
            <div class="stack">
              <div class="section-tag section-tag-light">{page.proof.tag}</div>
              <p class="proof-intro">{page.proof.intro}</p>
            </div>
            <p class="proof-callout">{page.proof.callout}</p>
          </div>

          <div class="logo-rail" aria-label="Références clients">
            {page.proof.logos.map((logo) => (
              <article
                class="client-logo-card"
                data-proof-status={logo.status}
                data-supported-claim={logo.supportedClaim}
              >
                <img
                  src={assetPath(logo.src)}
                  alt={`Logo ${logo.label}`}
                  loading="lazy"
                  decoding="async"
                />
                <div>
                  <strong>{logo.label}</strong>
                  <span>{logo.context}</span>
                  <small>{logo.supportedClaim}</small>
                </div>
              </article>
            ))}
          </div>

          <div class="proof-rail">
            {page.proof.items.map((item) => (
              <div
                class="proof-item"
                data-proof-status={item.status}
                data-supported-claim={item.supportedClaim}
              >
                {item.label}
                <span>{item.meta}</span>
                <small>{item.supportedClaim}</small>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section-block" id="work">
      <div class="shell shell-wide">
        <div class="section-heading">
          <div class="stack">
            <div class="section-tag">{page.work.tag}</div>
            <h2 class="section-title">{page.work.title}</h2>
          </div>
          <p class="lede">{page.work.intro}</p>
        </div>

        <div class="work-grid">
          <article class="panel work-feature">
            <div class="section-meta">
              <span class="kicker">{page.work.featured.kicker}</span>
              <span class="meta">{page.work.featured.meta}</span>
            </div>
            <h3 class="card-title">{page.work.featured.title}</h3>
            <p class="card-copy">{page.work.featured.body}</p>
          </article>

          {page.work.cards.map((card, index) => (
            <article class={`panel work-card work-card-${index + 1}`}>
              <span class="kicker">{card.kicker}</span>
              <h3 class="card-title">{card.title}</h3>
              <p class="card-copy">{card.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-block" id="testimonials">
      <div class="shell shell-wide">
        <div class="section-heading">
          <div class="stack">
            <div class="section-tag">{page.testimonials.tag}</div>
            <h2 class="section-title">{page.testimonials.title}</h2>
          </div>
          <p class="lede">{page.testimonials.intro}</p>
        </div>

        <div class="testimonial-grid">
          {page.testimonials.cards.map((card, index) => (
            <article
              class={`panel testimonial-card testimonial-card-${index + 1}`}
              data-proof-status={card.status}
              data-supported-claim={card.supportedClaim}
            >
              <p class="quote">"{card.quote}"</p>
              <div class="quote-byline">
                <strong>{card.attribution}</strong>
                <div class="meta">{card.meta}</div>
                <small>{card.supportedClaim}</small>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-block" id="contact">
      <div class="shell shell-wide">
        <div class="panel cta-panel">
          <div class="stack">
            <div class="section-tag section-tag-light">{page.contact.tag}</div>
            <h2 class="cta-title">{page.contact.title}</h2>
            <div class="hero-bubble cta-bubble">
              <span class="bubble-kicker">Booking V1</span>
              <p>{page.contact.note}</p>
            </div>
          </div>
          <div class="cta-side">
            <ul class="list">
              {page.contact.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
            <div class="cta-actions">
              <a class="button button-primary" href={page.contact.primaryCta.href}>
                {page.contact.primaryCta.label}
              </a>
              <a class="button button-secondary" href={page.contact.secondaryCta.href}>
                {page.contact.secondaryCta.label}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
