---
import PersonaPlaceholder from "../components/PersonaPlaceholder.astro";
import { homepageFr } from "../data/homepage.fr";
import BaseLayout from "../layouts/BaseLayout.astro";

const page = homepageFr;
---

<BaseLayout title={page.meta.title} description={page.meta.description}>
  <header class="topbar">
    <div class="shell shell-wide topbar-inner">
      <a class="brand" href="#top" aria-label={`Accueil ${page.topbar.brand}`}>
        <span class="brand-mark" aria-hidden="true"></span>
        <span class="brand-copy">
          <span class="brand-title">{page.topbar.brand}</span>
          <span class="brand-meta">{page.topbar.meta}</span>
        </span>
      </a>

      <nav class="nav" aria-label="Navigation principale">
        {page.topbar.nav.map((item) => <a href={item.href}>{item.label}</a>)}
        <a class="button button-primary" href={page.topbar.cta.href}>{page.topbar.cta.label}</a>
      </nav>
    </div>
  </header>

  <main class="page">
    <section class="hero-band" id="top">
      <div class="shell shell-wide hero">
        <article class="panel hero-copy">
          <div class="stack hero-copy-stack">
            <div class="eyebrow">{page.hero.eyebrow}</div>
            <h1>{page.hero.title}</h1>
            <p class="hero-text">{page.hero.body}</p>
            <div class="hero-actions">
              <a class="button button-primary" href={page.hero.primaryCta.href}>
                {page.hero.primaryCta.label}
              </a>
              <a class="button button-secondary" href={page.hero.secondaryCta.href}>
                {page.hero.secondaryCta.label}
              </a>
            </div>
          </div>

          <div class="hero-bubble" aria-label={page.hero.bubble.kicker}>
            <span class="bubble-kicker">{page.hero.bubble.kicker}</span>
            <p>{page.hero.bubble.body}</p>
          </div>

          <div class="chips" aria-label="Pastilles de preuve">
            {page.hero.chips.map((chip) => <span class="chip">{chip}</span>)}
          </div>
        </article>

        <div class="hero-stage">
          <article class="panel hero-stage-board">
            <div class="slot-label slot-label-ink">Personnage principal</div>
            <PersonaPlaceholder />
            <div class="persona-caption">
              <strong>{page.hero.persona.caption}</strong>
              <p>{page.hero.persona.body}</p>
            </div>
          </article>

          <aside class="sticky-note hero-note">
            <span class="note-kicker">{page.hero.sticky.kicker}</span>
            <strong>{page.hero.sticky.title}</strong>
            <p>{page.hero.sticky.body}</p>
          </aside>

          <article class="spec-card">
            <div class="slot-label slot-label-dark">{page.hero.persona.title}</div>
            <ul class="spec-list">
              {page.hero.persona.specs.map((spec) => (
                <li>
                  <span class="spec-label">{spec.label}</span>
                  <span class="spec-value">{spec.value}</span>
                </li>
              ))}
            </ul>
          </article>

          <article class="proof-flash">
            <span class="meta">{page.hero.proofFlash.kicker}</span>
            <strong>{page.hero.proofFlash.title}</strong>
            <p>{page.hero.proofFlash.body}</p>
          </article>
        </div>
      </div>
    </section>

    <section class="proof-band" id="proof">
      <div class="shell shell-wide">
        <div class="panel proof-wrap">
          <div class="proof-head">
            <div class="stack">
              <div class="section-tag section-tag-light">{page.proof.tag}</div>
              <p class="proof-intro">{page.proof.intro}</p>
            </div>
            <p class="proof-callout">{page.proof.callout}</p>
          </div>

          <div class="proof-rail">
            {page.proof.items.map((item) => (
              <div class="proof-item">
                {item.label}
                <span>{item.meta}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section-block" id="work">
      <div class="shell shell-wide">
        <div class="section-heading">
          <div class="stack">
            <div class="section-tag">{page.work.tag}</div>
            <h2 class="section-title">{page.work.title}</h2>
          </div>
          <p class="lede">{page.work.intro}</p>
        </div>

        <div class="work-grid">
          <article class="panel work-feature">
            <div class="section-meta">
              <span class="kicker">{page.work.featured.kicker}</span>
              <span class="meta">{page.work.featured.meta}</span>
            </div>
            <h3 class="card-title">{page.work.featured.title}</h3>
            <p class="card-copy">{page.work.featured.body}</p>
          </article>

          {page.work.cards.map((card, index) => (
            <article class={`panel work-card work-card-${index + 1}`}>
              <span class="kicker">{card.kicker}</span>
              <h3 class="card-title">{card.title}</h3>
              <p class="card-copy">{card.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-block" id="method">
      <div class="shell shell-wide">
        <div class="section-heading">
          <div class="stack">
            <div class="section-tag">{page.method.tag}</div>
            <h2 class="section-title">{page.method.title}</h2>
          </div>
          <p class="lede">{page.method.intro}</p>
        </div>

        <div class="method-grid">
          {page.method.steps.map((step) => (
            <article class="panel method-card">
              <span class="method-index">{step.index}</span>
              <h3 class="card-title">{step.title}</h3>
              <p class="card-copy">{step.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-block" id="editorial">
      <div class="shell shell-wide">
        <div class="section-heading">
          <div class="stack">
            <div class="section-tag">{page.editorial.tag}</div>
            <h2 class="section-title">{page.editorial.title}</h2>
          </div>
          <p class="lede">{page.editorial.intro}</p>
        </div>

        <div class="territory-grid">
          <article class="panel territory-feature">
            <div class="slot-label">{page.editorial.featureLabel}</div>
            <h3 class="card-title">{page.editorial.featureTitle}</h3>
            <p class="card-copy">{page.editorial.featureBody}</p>
            <p class="feature-note">{page.editorial.featureNote}</p>
          </article>

          {page.editorial.cards.map((card) => (
            <article class="panel territory-card">
              <div class="mini-stack">
                {card.labels.map((label) => <span class="mini-tag">{label}</span>)}
              </div>
              <p class="card-copy">{card.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-block" id="testimonials">
      <div class="shell shell-wide">
        <div class="section-heading">
          <div class="stack">
            <div class="section-tag">{page.testimonials.tag}</div>
            <h2 class="section-title">{page.testimonials.title}</h2>
          </div>
          <p class="lede">{page.testimonials.intro}</p>
        </div>

        <div class="testimonial-grid">
          {page.testimonials.cards.map((card, index) => (
            <article class={`panel testimonial-card testimonial-card-${index + 1}`}>
              <p class="quote">"{card.quote}"</p>
              <div class="quote-byline">
                <strong>{card.attribution}</strong>
                <div class="meta">{card.meta}</div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-block" id="insights">
      <div class="shell shell-wide">
        <div class="section-heading">
          <div class="stack">
            <div class="section-tag">{page.insights.tag}</div>
            <h2 class="section-title">{page.insights.title}</h2>
          </div>
          <p class="lede">{page.insights.intro}</p>
        </div>

        <div class="insight-grid">
          {page.insights.cards.map((card, index) => (
            <article class={`panel insight-card insight-card-${index + 1}`}>
              <div class="thumb">
                <div class="slot-label">Visuel note</div>
              </div>
              <span class="kicker">{card.kicker}</span>
              <h3 class="card-title">{card.title}</h3>
              <p class="card-copy">{card.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-block" id="contact">
      <div class="shell shell-wide">
        <div class="panel cta-panel">
          <div class="stack">
            <div class="section-tag section-tag-light">{page.contact.tag}</div>
            <h2 class="cta-title">{page.contact.title}</h2>
            <div class="hero-bubble cta-bubble">
              <span class="bubble-kicker">Booking V1</span>
              <p>{page.contact.note}</p>
            </div>
          </div>
          <div class="cta-side">
            <ul class="list">
              {page.contact.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
            <div class="cta-actions">
              <a class="button button-primary" href={page.contact.primaryCta.href}>
                {page.contact.primaryCta.label}
              </a>
              <a class="button button-secondary" href={page.contact.secondaryCta.href}>
                {page.contact.secondaryCta.label}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
