---
type Props = {
  src?: string;
  alt?: string;
  class?: string;
  loading?: "eager" | "lazy";
};

const {
  src = "/brand/web/characters/pointing_up.png",
  alt = "The Unreliable Engineer",
  class: className = "",
  loading = "lazy",
} = Astro.props;

const resolvedSrc = src.startsWith("/") ? `${import.meta.env.BASE_URL}${src.slice(1)}` : src;
---

<img
  class:list={["character-asset", className]}
  src={resolvedSrc}
  alt={alt}
  loading={loading}
  decoding="async"
/>
