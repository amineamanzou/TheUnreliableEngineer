---
import "../styles/global.css";
import type { Locale } from "../data/i18n";
import { assetPath, localizedPath } from "../data/i18n";

type Props = {
  title: string;
  description: string;
  locale?: Locale;
  lang?: Locale;
  canonicalPath?: string;
  alternates?: Array<{ locale: Locale; path: string }>;
  enableLocaleRedirect?: boolean;
  localeRedirectPath?: string;
  localeRedirectPaths?: { fr: string; en: string };
};

const {
  title,
  description,
  locale,
  lang,
  canonicalPath,
  alternates = [],
  enableLocaleRedirect = false,
  localeRedirectPath = "/",
  localeRedirectPaths,
} = Astro.props;
const pageLocale = locale ?? lang ?? "fr";
const canonicalUrl = canonicalPath && Astro.site ? new URL(assetPath(canonicalPath), Astro.site).toString() : undefined;
const alternateLinks = Astro.site
  ? alternates.map((alternate) => ({
      locale: alternate.locale,
      href: new URL(assetPath(alternate.path), Astro.site).toString(),
    }))
  : [];
const baseUrl = import.meta.env.BASE_URL;
const redirectPathFr = assetPath(localeRedirectPaths?.fr ?? localizedPath("fr", localeRedirectPath));
const redirectPathEn = assetPath(localeRedirectPaths?.en ?? localizedPath("en", localeRedirectPath));
const xDefaultPath =
  alternates.find((alternate) => alternate.locale === "fr")?.path ?? canonicalPath ?? "/";
---

<!doctype html>
<html lang={pageLocale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {alternateLinks.map((alternate) => <link rel="alternate" hreflang={alternate.locale} href={alternate.href} />)}
    {alternateLinks.length > 0 && Astro.site && <link rel="alternate" hreflang="x-default" href={new URL(assetPath(xDefaultPath), Astro.site).toString()} />}
  </head>
  <body>
    {
      enableLocaleRedirect && (
        <script is:inline define:vars={{ baseUrl, redirectPathFr, redirectPathEn }}>
          const relativePath = window.location.pathname.startsWith(baseUrl)
            ? window.location.pathname.slice(baseUrl.length - 1)
            : window.location.pathname;
          const preferredLocale = window.localStorage.getItem("preferredLocale");
          const browserLocales = navigator.languages ?? [navigator.language ?? "fr"];
          const preferredSupportedLocale = browserLocales
            .map((value) => String(value).toLowerCase())
            .map((value) => (value.startsWith("en") ? "en" : value.startsWith("fr") ? "fr" : null))
            .find(Boolean);

          if (!preferredLocale && relativePath === redirectPathFr.replace(baseUrl, "/") && preferredSupportedLocale === "en") {
            window.location.replace(`${redirectPathEn}${window.location.hash}`);
          }
        </script>
      )
    }
    <slot />
  </body>
</html>
